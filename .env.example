# ── Telegram ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Admin foydalanuvchi IDlari (vergul bilan ajrating) ──
# Telegram ID'ingizni bilish uchun @userinfobot ga /start yuboring
ADMIN_USER_IDS=123456789,987654321

# ── Firebase ──────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Cloud Run (production uchun) ──────────────────
# Webhook URL — Cloud Run servis URL'i
WEBHOOK_URL=https://your-cloud-run-url.a.run.app
PORT=8080
